#include <stdio.h>
#include<string.h>
int main()
{
    /*for two equal strings*/
    char s1[1000],s2[1000];
    int i,c=0,count1=0,count2=0,j,flag;
    printf("Enter the first string to check equality and subscript\n");
    gets(s1);
    printf("Enter the second string to check equality and subscript\n");
    gets(s2);
    if(strlen(s1)==strlen(s2))
    {
        for(i=0;s2[i]!='\0';i++)
        {
            if(s1[i]==s2[i])
            c++;
        }
        if(c==i)
        {
            printf("\nstrings are equal");
        }
        else
        {
            printf("\nstrings are unequal");
        }
    }
    else
    {
        printf("\nstrings are not equal");
    }
    while(s1[count1]!='\0')
    count1++;
    while(s2[count2]!='\0')
    count2++;
    for (i = 0; i <= count1 - count2; i++)
    {
        for (j = i; j < i + count2; j++)
        {
            flag = 1;
            if (s1[j]!= s2[j - i])
            {
                flag = 0;
                break;
            }
        }
        if (flag == 1)
            break;
    }
    if (flag == 1)
        printf("\nThere is subscript");
    else
        printf("\nThere is not any subscript");
    return 0;
}

 
